# Configuration for the MLWH MCP server (mcp-server).
#
# For LOCAL runs: copy this to .env (`make config`) and edit, then `make start`.
# For real use: set these in your MCP client's server config instead (see the
# README's Claude Code / Codex sections) - the client launches the binary and
# passes this environment to it.

# Base URL of the "wa mlwh serve" HTTP API this server bridges to. REQUIRED.
# Point it at your running wa MLWH instance (example value shown).
MLWH_BASE_URL=http://localhost:8080

# Optional: path to a PEM CA-certificate file, if the MLWH API is served over
# TLS with a private CA. Omit for plain HTTP.
# MLWH_CA_CERT=/path/to/ca.pem

# Optional: per-request HTTP timeout as a Go duration (e.g. 15s, 30s, 1m).
# Omit to use the client default.
# MLWH_TIMEOUT=30s
